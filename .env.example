# =============================================================================
# Tagly — Environment Variables
# Copy to .env and adjust values for your environment.
# =============================================================================

# -- Database -----------------------------------------------------------------
DB_NAME=tagly
DB_USER=tagly
DB_PASSWORD=tagly_dev
DB_HOST=localhost
DB_PORT=5432
# Docker Compose only: published host port for the db service (default 5432). Use 5433 if you see "port is already allocated" on 5432.
POSTGRES_HOST_PORT=5432

# -- Redis --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Docker Compose only: published host port for the redis service (default 6379). Use 6380 if you see "port is already allocated" on 6379.
REDIS_HOST_PORT=6379

# -- Django -------------------------------------------------------------------
# Used by Django for sessions, CSRF, etc. `docker compose` reads this file and passes it into backend/celery (see docker-compose.yml).
# Do not put this in the frontend or in Cloudflare — never commit real values.
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=0
# Cloudflare Tunnel / reverse proxy: set 1 on the Pi so Django trusts X-Forwarded-Proto and sets secure cookies.
DJANGO_BEHIND_HTTPS_PROXY=0
# Add your Raspberry Pi IP and any other hosts that should be allowed
# ALLOWED_HOSTS must include the API hostname if using a tunnel (e.g. tagly-backend.brandstaetter.rocks).
ALLOWED_HOSTS=tagly-backend.brandstaetter.rocks,tagly.brandstaetter.rocks,localhost,192.168.0.150
SERVER_URL=https://tagly.brandstaetter.rocks
HOST_IP=192.168.0.150
PORT=8008

# -- CORS ---------------------------------------------------------------------
# Include every browser origin that loads the SPA (https for Cloudflare). Example split API host:
# API: tagly-backend.brandstaetter.rocks → Frontend: https://tagly.brandstaetter.rocks
CORS_ALLOWED_ORIGINS=https://tagly.brandstaetter.rocks,http://localhost:5173,http://192.168.0.150:5173,http://192.168.0.150:8008,https://tagly-backend.brandstaetter.rocks
# CSRF: same origins as CORS; add https://tagly-backend... if you open admin/API on the API hostname.
CSRF_TRUSTED_ORIGINS=https://tagly.brandstaetter.rocks,http://localhost:5173,http://192.168.0.150:5173,http://192.168.0.150:8008,https://tagly-backend.brandstaetter.rocks

# -- Email (SMTP / Gmail) -----------------------------------------------------
# For Gmail: use an App Password (not your regular password).
# Generate one at https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=your-gmail@gmail.com

# -- Logging ------------------------------------------------------------------
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# -- Frontend -----------------------------------------------------------------
# REQUIRED when you open the app at https://tagly.brandstaetter.rocks (or any public HTTPS URL):
# Use the public API base URL (same scheme https), NOT http://192.168.x.x — otherwise the browser blocks requests
# (Local Network Access) and CORS/session cookies fail.
# VITE_API_URL=https://tagly-backend.brandstaetter.rocks/api/v1
# Local dev / LAN-only (docker-compose default if unset): falls back to http://${HOST_IP}:8008/api/v1
VITE_API_URL=http://localhost:8008/api/v1
# Optional: comma-separated extra hostnames for Vite dev (server.allowedHosts), e.g. another tunnel hostname
# Hostnames only (no https://); optional extra tunnel hosts for Vite
# VITE_ALLOWED_HOSTS=tagly-backend.brandstaetter.rocks
